if(NOT DEFINED OUTPUT_HEADER OR OUTPUT_HEADER STREQUAL "")
    message(FATAL_ERROR "Missing OUTPUT_HEADER")
endif()
if(NOT DEFINED INPUT_BOOTSTRAP OR INPUT_BOOTSTRAP STREQUAL "")
    message(FATAL_ERROR "Missing INPUT_BOOTSTRAP")
endif()
if(NOT DEFINED INPUT_SB_PROFILE OR INPUT_SB_PROFILE STREQUAL "")
    message(FATAL_ERROR "Missing INPUT_SB_PROFILE")
endif()

function(embed_escape INPUT_TEXT OUTPUT_VAR)
    set(escaped "${INPUT_TEXT}")
    string(REPLACE "\\" "\\\\" escaped "${escaped}")
    string(REPLACE "\"" "\\\"" escaped "${escaped}")
    string(REPLACE "\r" "" escaped "${escaped}")
    string(REPLACE "\n" "\\n\" \\\n    \"" escaped "${escaped}")
    set(${OUTPUT_VAR} "${escaped}" PARENT_SCOPE)
endfunction()

set(header_text "// Auto-generated file - DO NOT EDIT\n")
string(APPEND header_text "// Generated by cmake/user/generate_embed.cmake\n\n")
string(APPEND header_text "#ifndef EMBED_H\n")
string(APPEND header_text "#define EMBED_H\n\n")

set(embed_files
    "${INPUT_BOOTSTRAP}|BOOTSTRAP_LUA"
    "${INPUT_SB_PROFILE}|SB_PROFILE"
)

foreach(pair IN LISTS embed_files)
    string(REPLACE "|" ";" pair_parts "${pair}")
    list(GET pair_parts 0 input_file)
    list(GET pair_parts 1 var_name)
    if(EXISTS "${input_file}")
        file(READ "${input_file}" file_content)
        embed_escape("${file_content}" escaped_content)
        string(APPEND header_text "const char* ${var_name} = \"${escaped_content}\";\n\n")
    else()
        message(WARNING "Embed input not found: ${input_file} (using empty string)")
        string(APPEND header_text "const char* ${var_name} = \"\";\n\n")
    endif()
endforeach()

string(APPEND header_text "#endif // EMBED_H\n")
file(WRITE "${OUTPUT_HEADER}" "${header_text}")
message(STATUS "Generated ${OUTPUT_HEADER}")
